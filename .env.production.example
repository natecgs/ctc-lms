# Production Environment Variables

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
NODE_ENV=production
PORT=5000
HOST=0.0.0.0

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DB_HOST=your_production_db_host.rds.amazonaws.com
DB_PORT=5432
DB_USER=lms_app
DB_PASSWORD=your_secure_database_password_here
DB_NAME=ctc_lms_prod
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_CONNECTION_TIMEOUT_MS=5000
DB_IDLE_TIMEOUT_MS=30000
DB_STATEMENT_TIMEOUT_MS=30000

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================
FRONTEND_URL=https://your-production-domain.com
VITE_API_URL=https://your-production-domain.com/api

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
JWT_SECRET=generate_with_openssl_rand_base64_32_min_32_chars
JWT_EXPIRY=7d
JWT_REFRESH_SECRET=generate_with_openssl_rand_base64_32_min_32_chars
JWT_REFRESH_EXPIRY=30d
BCRYPT_ROUNDS=12

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================
# Gmail with App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM=noreply@your-domain.com
SMTP_FROM_NAME=CTC LMS

# Alternative: SendGrid
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=SG.your_sendgrid_api_key

# Alternative: AWS SES
# SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# SMTP_PORT=587
# SMTP_USER=your_ses_username
# SMTP_PASSWORD=your_ses_password

# ============================================================================
# RATE LIMITING & SECURITY
# ============================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX_REQUESTS=5

# ============================================================================
# LOGGING & MONITORING
# ============================================================================
LOG_LEVEL=info
LOG_FORMAT=json
SENTRY_DSN=https://your_sentry_dsn_key@sentry.io/project_id

# ============================================================================
# SUPABASE / THIRD-PARTY SERVICES
# ============================================================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ============================================================================
# PERFORMANCE & OPTIMIZATION
# ============================================================================
NODE_OPTIONS=--max-old-space-size=2048
SESSION_TIMEOUT_MS=3600000

# ============================================================================
# FEATURE FLAGS
# ============================================================================
FEATURE_EMAIL_VERIFICATION=true
FEATURE_COURSE_REVIEWS=true
FEATURE_CERTIFICATES=true

# ============================================================================
# DO NOT COMMIT THIS FILE TO VERSION CONTROL
# Use .env.production.local for local overrides
# Store secrets using: AWS Secrets Manager, HashiCorp Vault, or similar
# ============================================================================
